{
    "type": "notice",
    "title": "ASU tutorial",
    "body": {
            "type": "plain_message",
            "contents": [
                {"text": "Welcome to Armor Stand Utils!", "bold": true},
                {"text": "\nThis datapack allows you to modify some properties of Armor Stands using Name Tags.", "bold": false},
                {"text": "\nJust click an Armor Stand with the correct Name Tag to modify it.", "bold": false},
                {"text": "\nHere is a list of all compatible Name Tags:", "bold": true, "color": "green"},
                {"text": "\narms", "bold": true, "extra": [{"text": " - Gives the Armor Stand arms.", "bold": false}]},
                {"text": "\nnoarms", "bold": true, "extra": [{"text": " - Removes the arms.", "bold": false}]},
                {"text": "\nnoplate", "bold": true, "extra": [{"text": " - Removes the Armor Stand's baseplate.", "bold": false}]},
                {"text": "\nplate", "bold": true, "extra": [{"text": " - Returns the baseplate.", "bold": false}]},
                {"text": "\nsmall", "bold": true, "extra": [{"text": " - Makes the Armor Stand small.", "bold": false}]},
                {"text": "\nbig", "bold": true, "extra": [{"text": " - Makes the Armor Stand big.", "bold": false}]},
                {"text": "\nclockwise", "bold": true, "extra": [{"text": " - Rotates the Armor Stand 45 degrees clockwise.", "bold": false}]},
                {"text": "\ncounterclockwise", "bold": true, "extra": [{"text": " - Rotates the Armor Stand 45 degrees counterclockwise.", "bold": false}]},
                {"text": "\nTo uninstall, run '/function asu:uninstall'(permission level 2+). Then, delete the datapack and run '/reload'(permission level 2+).", "bold": true,"color": "red"},
                {"text": "\nDO NOT DELETE BEFORE UNINSTALLING!", "bold":true, "color": "red"},
                {"text": "\nTo reset all Armor Stands to their default states, run '/function asu:reset'(permission level 2+)", "bold": true, "color": "yellow"}
            ]
    }
}